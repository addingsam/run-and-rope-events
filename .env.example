# =============================================================================
# Jackpot & Rodeo Events — environment variables
# Copy to `.env.local` for local dev. Add the same keys in Vercel → Settings →
# Environment Variables for Production (and Preview if desired).
# =============================================================================

# -----------------------------------------------------------------------------
# App URL (required in production)
# Used for Stripe Checkout redirects, saved-search alert emails, etc.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Supabase (required)
# Project Settings → API in the Supabase dashboard.
# Server-side code uses the service role key only — never expose it to the client.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: only needed if you add client-side Supabase usage later.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Clerk authentication (required)
# Clerk Dashboard → API Keys + Webhooks.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Clerk route overrides (safe to keep these defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/events
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/subscribe

# -----------------------------------------------------------------------------
# Stripe subscriptions (required)
# Stripe Dashboard → Developers → API keys + Webhooks + Products/Prices.
# Checkout is server-side (Stripe Checkout Sessions) — publishable key not used.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_ANNUAL_ID=
STRIPE_PRICE_FEATURED_ID=
STRIPE_PRICE_FEATURED_RECURRING_ID=

# Optional — not used by the current codebase (no client-side Stripe.js).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Resend email (required for submission confirmations + saved-search alerts)
# Resend Dashboard → API Keys → verify sender email or domain.
# Use the same team inbox for outbound (FROM) and contact form delivery (ADMIN_EMAIL).
# Verify jackpotandrodeoevents@gmail.com in Resend before production send.
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=Jackpot & Rodeo Events <jackpotandrodeoevents@gmail.com>

# -----------------------------------------------------------------------------
# Mapbox (required for geocoding, route search, and the events map)
# Mapbox → Access tokens. Use a public token (pk.) with URL restrictions.
# The map token is passed to the browser for Mapbox GL — restrict by domain.
# -----------------------------------------------------------------------------
MAPBOX_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Anthropic (required for /submit flyer extraction)
# Anthropic Console → API keys.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Cloudflare R2 flyer uploads (required for /submit flyer uploads)
# Cloudflare Dashboard → R2 → Manage R2 API tokens + public bucket URL.
# -----------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Cron jobs (optional on Vercel — Vercel Cron sends x-vercel-cron automatically)
# Set CRON_SECRET if you call cron routes manually or from an external scheduler.
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Admin (optional — legacy pro-rodeo password form; /admin uses Clerk role instead)
# ADMIN_EMAIL receives /contact form messages. Use the same inbox as RESEND_FROM_EMAIL.
# -----------------------------------------------------------------------------
ADMIN_SECRET=
ADMIN_EMAIL=jackpotandrodeoevents@gmail.com
